# Spotify Web API -tunnukset
# Luo: https://developer.spotify.com/dashboard
SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8765/callback

# Käyttäjäkohtaiset asetukset
SPOTIFY_USER_ID=your_spotify_user_id

# Valinnaiset - vaihtoehtoiset tietolähteet
LASTFM_API_KEY=                       # Fallback genre-dataan
DISCOGS_TOKEN=                        # Levyjen metadata
