# Spotify Curator deployment env file
# Copy to .env and fill in. NEVER commit .env to git.

# ──── Hermes Agent ────────────────────────────────────────────
# Required: one of the LLM providers below must be set
OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# DEEPSEEK_API_KEY=

# Default model the agent uses (provider/model format)
HERMES_MODEL=anthropic/claude-sonnet-4

# Profile name (matches HERMES_PROFILE in compose.yml)
HERMES_PROFILE=spotify-curator

# ──── Spotify Web API ──────────────────────────────────────────
# Create: https://developer.spotify.com/dashboard
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8765/callback
# Path inside container where the OAuth token cache is mounted
SPOTIPY_CACHE_PATH=/opt/secrets/spotify_cache

# ──── Last.fm API ──────────────────────────────────────────────
# Create: https://www.last.fm/api/account/create
LASTFM_API_KEY=

# ──── Spotify Curator runtime ─────────────────────────────────
# Where profiles, reports, and IPC socket live (inside container)
SPOTIFY_CURATOR_HOME=/opt/data/spotify-curator

# Disable browser-opening anywhere — this is a headless container
SPOTIPY_OPEN_BROWSER=false

# ──── Telegram bot (optional, for gateway notifications) ──────
# Get from @BotFather, then use Hermes to send to your chat_id
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
